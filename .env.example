# ── Copier ce fichier : cp .env.example .env.local puis remplir les valeurs. ──

# OBLIGATOIRE pour que le formulaire puisse envoyer le bon (sans clé = message d’erreur sur le formulaire).
# Créer un compte sur https://resend.com → API Keys → clé re_…
# Ne dupliquez pas la variable : une seule ligne RESEND_API_KEY=… sinon la première valeur (vide ?) peut gagner.
# IMPORTANT (test) : avec @onboarding.resend.dev, Resend peut refuser tout destinataire qui n’est pas
# dans « Allowed recipients » (domaine vérif ou ajout manuel) — ça bloque alors N’IMPORTE QUEL mail y compris gmail.
# Pour tout le monde comme clients : vérifiez un domaine sur Resend puis EMAIL_FROM=@votredomaine.fr
RESEND_API_KEY=

# Expéditeur : avec onboarding@resend.dev en test uniquement ;
# avec un domaine vérifié sur Resend, mettez par ex. : bon@votredomaine.fr
EMAIL_FROM=La roulette cadeau <onboarding@resend.dev>

# URL du site utilisée dans les liens des mails (sans slash final si une seule valeur)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret qui signe le lien dans le mail (« ?token=… »). Obligatoire en prod ;
# en dev, si vous le laissez vide, tous les envois utilisent le même défaut fixe du code.
# CRITIQUE : la même valeur sur la machine qui envoie le mail ET celle où l’URL est ouverte
# (ex. lien envoyé depuis Vercel avec secret A alors que vous ouvrez en local avec secret B
# → erreur « mauvaise signature »). Après avoir changé cette variable : renvoyer un nouveau mail de test.
GIFT_TOKEN_SECRET=

# ── Suivi première ouverture du lien cadeau (optionnel en local ; recommandé en prod) ──
# Sans Upstash ni KV : tout est stocké dans data/gift-opens.json (correct en npm run dev).
# Sur Vercel le disque n’est PAS persistant pour ce fichier → en prod ajoutez Upstash Redis (gratuit).
# L’ouverture du mail / la page cadeau fonctionne sans Redis ; Redis sert uniquement à mémoriser si le lot a déjà été dévoilé entre les hits serveur.
# Dashboard : https://console.upstash.com → Create database → puis coller REST URL / token.
# Compatibilité avec le template Vercel KV : KV_REST_API_URL / KV_REST_API_TOKEN fonctionnent aussi.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Champ e-mail prérempli (optionnel ; prioritaire sur l’adresse codée pour la démo ; voir NEXT_PUBLIC_DEMO_REPLAY ci‑dessous).
# NEXT_PUBLIC_GIFT_EMAIL_PREFILL=

# Secondes après l’avis Google avant la roulette (0 = pas d’attente). Défaut 6.
NEXT_PUBLIC_ROULETTE_UNLOCK_SECONDS=6

# Démo présentoir (bouton « Rejouer »…) ; prérempli e‑mail démo si besoin. NE PAS en prod cliente.
# NEXT_PUBLIC_DEMO_REPLAY=true

# Même comportement démo pour l’API send-gift (sans préfixe PUBLIC = valeur lue à l’exécution ; à ajouter aussi sur Vercel si « déjà reçu un bon » alors que DEMO_REPLAY est à true dans le tableau de bord — souvent le bundle a été compilé avant l’activation de NEXT_PUBLIC_*).
# SKIP_GIFT_EMAIL_SEND_COOLDOWN=true

# Passer sans avis — UNIQUEMENT dev/tests. Sinon laisser commenté ou false.
# NEXT_PUBLIC_REVIEW_SKIP_ENABLED=true

# TTL cookie session jeu après déblocage (ms). Défaut 3 h sans variable.
# PLAY_SESSION_TTL_MS=10800000

# Séparé du secret mails ; défaut : GIFT_TOKEN_SECRET.
# PLAY_SESSION_SECRET=

# ─── Protection anti ré-envois même e-mail (voir `lib/email-send-rate-limit.ts`) ───
# Présentoir / tests : garder commenté ; utiliser plutôt SKIP_GIFT + (optionnel) NEXT_PUBLIC_DEMO_REPLAY.
#
# **Livraison projet client (Vercel prod)** : ajouter sur l’environnement déployé :
# EMAIL_REPEAT_PROTECT=true
# Puis supprimer ou commenter toute variable « présentoir » : SKIP_GIFT_EMAIL_SEND_COOLDOWN, RATE_LIMIT_EMAIL_MS=0,
# NEXT_PUBLIC_DEMO_REPLAY, préremplissage e-mail démo, etc. Liste complète : AGENTS.md

# Anti-abus : délai minimum entre deux envois au MÊME e-mail (millisecondes).
# — Démo&nbsp;: soit `RATE_LIMIT_EMAIL_MS=0`, soit SKIP_GIFT ci‑dessus, soit `NEXT_PUBLIC_DEMO_REPLAY` (avec un rebuild si nécessaire).
# — CLIENTS en prod&nbsp;: omis ou ex.&nbsp;: RATE_LIMIT_EMAIL_MS=86400000 (24 h).
# Défaut sans aucune désactivation&nbsp;: 24 h.
# RATE_LIMIT_EMAIL_MS=0

# Borne si valeur trop grande (ms). Défaut 7 jours sans variable.

# RATE_LIMIT_EMAIL_MAX_MS=
